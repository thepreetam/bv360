# Vercel Postgres - Database connection
# Create a Postgres database at https://vercel.com/dashboard → Storage → Create Database
# Then link it to your project
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Gemini AI (optional - leave blank to use mock AI)
# Get your API key at https://aistudio.google.com/
GEMINI_API_KEY=